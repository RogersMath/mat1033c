{
  "id": "distance",
  "title": "Distance Formula",
  "latex": "d = \\sqrt{(x_2 - x_1)^2 + (y_2 - y_1)^2}",

  "notes": [
    "The distance formula comes from the Pythagorean Theorem.",
    "It measures the straight-line distance between two points.",
    "Often paired with slope and midpoint in coordinate geometry."
  ],

  "examples": [
    {
      "description": "Find the distance between (1, 2) and (5, 7).",
      "latex": "d = \\sqrt{(5-1)^2 + (7-2)^2} = \\sqrt{16 + 25} = \\sqrt{41}"
    }
  ],

  "applications": [
    "Geometry, GPS coordinates, physics, and real-world distance measurements.",
    "Understanding diagonal or non-horizontal/vertical distances."
  ],

